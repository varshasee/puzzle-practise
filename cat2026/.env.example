# ────────────────────────────────────────────────────────────
# CAT 2026 Puzzle Practice — Environment Variables
# ────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values below.
# .env.local is gitignored and never deployed with your code.

# ── Supabase (required) ──────────────────────────────────────
# Found at: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Service role key — NEVER expose to browser, server actions only
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── App URL (required after first Vercel deploy) ──────────────
# Set to your Vercel URL or custom domain
NEXT_PUBLIC_APP_URL=https://cat2026-puzzle-practice.vercel.app

# ── Optional: invite code to restrict signups ────────────────
# INVITE_CODE=yourSecretWord
